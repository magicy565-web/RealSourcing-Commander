# ─── 数据库 ───────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/realsourcing_commander

# ─── Redis（BullMQ 任务队列）─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── 微信公众号（服务号，需申请模板消息权限）────────────────────
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_app_secret
WECHAT_TEMPLATE_LEAD_ARRIVED=your_template_id_1
WECHAT_TEMPLATE_TASK_PROGRESS=your_template_id_2
WECHAT_TEMPLATE_DAILY_REPORT=your_template_id_3

# ─── 飞书（Feishu/Lark）─────────────────────────────────────
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ─── OpenClaw Agent ──────────────────────────────────────────
OPENCLAW_API_URL=https://your-openclaw-instance.com
OPENCLAW_API_KEY=your_api_key
OPENCLAW_HMAC_SECRET=your_hmac_secret

# ─── AI 服务（复用 4.0 配置）────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# ─── Commander App ───────────────────────────────────────────
COMMANDER_APP_URL=https://app.commander.realsourcing.com
JWT_SECRET=your_jwt_secret

# ─── 账号 Session 加密密钥 ───────────────────────────────────
# 用于 AES-256 加密 OpenClaw 托管的平台账号 Session
SESSION_ENCRYPT_KEY=your_32_byte_hex_key
